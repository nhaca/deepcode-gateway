{
  "version": 2,
  "routes": [
    { "src": "/v1/chat/completions", "dest": "/api/chat.js" },
    { "src": "/v1/models", "dest": "/api/models.js" },
    { "src": "/v2/chat/completions", "dest": "/api/chat.js" },
    { "src": "/v2/models", "dest": "/api/models.js" },
    { "src": "/v3/chat/completions", "dest": "/api/chat.js" },
    { "src": "/v3/models", "dest": "/api/models.js" },
    { "src": "/v4/chat/completions/(.*)", "dest": "/api/chat.js" },
    { "src": "/v4/models", "dest": "/api/models.js" },
    { "src": "/bind-device", "dest": "/api/bind-device.js" }
  ]
}
